#!/bin/sh
# pre-commit — tier-0 overlay integrity gate for fable-method-harness.
#
# Runs the offline artifact validator (no network, no LLM, standard-library only).
# A nonzero exit blocks the commit — the overlay-local form of DR-011 no-silent-pass.
#
# Enable once per clone:   git config core.hooksPath scripts/hooks
# Bypass (discouraged, justify in the commit body):   git commit --no-verify
set -e

py=python
command -v python >/dev/null 2>&1 || py=py

# --quiet: FAIL lines + one-line summaries only. Success noise otherwise
# re-enters the committing agent's context on every commit (measured ~450
# tok/commit before this; verbose re-run: drop --quiet).
if ! "$py" scripts/check_agent_artifacts.py --quiet >&2; then
  echo "pre-commit: BLOCKED — overlay validation failed (see above)." >&2
  echo "            Fix the reported gap, or 'git commit --no-verify' to bypass." >&2
  exit 1
fi

if ! "$py" scripts/check_adaptive_harness.py --quiet >&2; then
  echo "pre-commit: BLOCKED — adaptive-harness validation failed (see above)." >&2
  echo "            Fix the reported gap, or 'git commit --no-verify' to bypass." >&2
  exit 1
fi

# INDEX.yaml drift gate: index_diff.py exits 1 on entry-vs-tracked drift,
# 2 on parse errors, one summary line on success. Previously convention-only
# (manual MT-5 sweeps) — INDEX grew +21% in 4 days with nothing enforcing sync.
if ! "$py" scripts/index_diff.py >&2; then
  echo "pre-commit: BLOCKED — INDEX.yaml out of sync with tracked files (see above)." >&2
  echo "            Fix INDEX.yaml entries, or 'git commit --no-verify' to bypass." >&2
  exit 1
fi
