# Secrets and credentials — never commit (docs/publication_status.md)
.env
.env.*
*.key
*.pem
secrets/
credentials*
*token*

# Language / tool caches
__pycache__/
*.pyc
.pytest_cache/
node_modules/
.venv/
venv/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Local scratch and logs
scratch/
tmp/
*.log

# Private local state (never part of the distillation)
local/
*.local.md
private/

# Claude Code local runtime state — the repo now tracks content under
# .claude/skills/, so these must be repo-ignored (not just by the operator's
# global git ignore, which does not travel with this PUBLIC repo).
.claude/settings.local.json
.claude/*.local.json
.claude/scheduled_tasks.lock

# Codebase-memory index + harvest staging — never part of the distillation
.codebase-memory/
distillation/harvest/

# AI-review / adaptive-harness generated report runs (same rationale as the
# orchestration_bench block below: FINDINGS live in tracked memory/ + the
# operator's ~/.claude/audits history, not in regenerable report artifacts).
# Privacy also applies: reports can embed telemetry harvested from the local
# ~/.claude harness scan, which must never land in a public repo.
reports/

# Orchestration-bench throwaway build outputs (the FINDINGS live in distillation-log.md,
# not in the 100s of generated trial packages). Keep the instrument (ladder.py, graders,
# tasks/ fixtures, evidence/ sample), ignore the generated runs + calibration scratch.
distillation/orchestration_bench/ladder_runs/
distillation/orchestration_bench/ladder_runs_v1_compressible/
distillation/orchestration_bench/calib/
distillation/orchestration_bench/calib_large/

# Operator-machine audit findings (never-include: local scan output) — decision
# records stay in 99_OPEN_OPTIMIZATION_SPACE.md; raw findings stay local. Glob,
# not exact names, so any FUTURE *findings*.json (phase3_, round3_, ...) is caught
# too. phase2_findings.json is already tracked (sanitized, user-accepted) and
# stays tracked — .gitignore never untracks an already-tracked file.
fable_ultracode_phase_workspace/*findings*.json

# A/B / harness-effect experiment output (evals/) — same rationale as reports/
# and the findings dumps: generated, machine-local, self-labeled pilot/proxy
# data that may embed absolute operator paths (e.g. a B-arm prompt citing a
# clone path). Durable results belong in docs/evidence.md, not in raw run dirs.
# Keep local; never sweep into this PUBLIC repo via a stray `git add -A`.
evals/
